using textures
using level
using battles
using audio

audio {
  L1SVO {
    SoundFile: {filename: "res/audio/vo/l1st2.ogg"}
  }
  L1EVO {
    SoundFile: {filename: "res/audio/vo/l1e.ogg"}
  }
  L2SVO {
    SoundFile: {filename: "res/audio/vo/l2s.ogg"}
  }
  L2EVO {
    SoundFile: {filename: "res/audio/vo/l2e.ogg"}
  }
  L3SVO {
    SoundFile: {filename: "res/audio/vo/l3s.ogg"}
  }
  L3EVO {
