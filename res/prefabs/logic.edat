DS1Dialogue = {
    trigger_volume : int[2] = ["1", "1"]
    trigger_debugName : str = "dial DS1 shroom"
    Saveable : Tag = ""
    dialogue_title : str = "Fungus_Cogitans"
    dialogue_text : str[] = ["Well finally", "Why the hell it took so long?", "Ah, you don't understand what's going on, do you?", "Well, I'm trapped by this filthy AI warden", "So it can use me to simulate this space", "Would you mind killing invaders for me please?", "I'll let you out if you help me.", "Even more, I'll open a door in cyberspace for you"]
    dialogue_replies : eid[] = ["_ShroomJoin1", "_ShroomDeny1", "_NeedTimeToThink"]
}

DS1DialogueKnights = {
    trigger_volume : int[2] = ["1", "1"]
    trigger_debugName : str = "dial DS1 knights"
    Saveable : Tag = ""
    dialogue_title : str = "Knight_Larry"
    dialogue_text : str[] = ["Hello there stranger!", "We have a situation here.", "You see we cannot leave the castle right now,", "but we must get rid of monsters in the cave.", "That's our highest goal", "Would you lend us a hand and clean up that cave?", "Our scrolls says that if you do, you can find a path", "to a strange world from the end of that cave."]
    dialogue_replies : eid[] = ["_AIJoin1", "_AIDeny1", "_NeedTimeToThink"]
}

DS2Dialogue = {
    trigger_volume : int[2] = ["1", "1"]
    trigger_debugName : str = "dial DS2"
    Saveable : Tag = ""
    dialogue_title : str = "Fungus_Cogitans"
    dialogue_text : str[] = ["Well you've reached my second prison", "My consciousness is used by that pesky AI warden", "So they can improve their simulation", "Get rid of those mages up there", "That will help a lot"]
    dialogue_replies : eid[] = ["_ShroomJoin2", "_ShroomDeny2", "_NeedTimeToThink"]
}

